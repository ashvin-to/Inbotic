# Google API Configuration
# Easiest setup: put your downloaded Google OAuth JSON at
# .secrets/google-credentials.json (or set GOOGLE_CREDENTIALS_PATH).
# The app auto-reads client_id/client_secret from that file.
GOOGLE_CREDENTIALS_PATH=.secrets/google-credentials.json

# Optional: inline credentials JSON (single env var)
# GOOGLE_OAUTH_CREDENTIALS_JSON={"web":{"client_id":"...","client_secret":"..."}}

# Optional manual values (only needed if not using credentials JSON)
CLIENT_ID=
CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# Optional: where to send users after successful OAuth login.
# Leave empty to stay on backend UI at http://localhost:8000/
FRONTEND_URL=http://localhost:5173

# Gmail Settings
GMAIL_MAX_EMAILS=20
GMAIL_DAYS_BACK=7
GMAIL_MARK_AS_READ=true
GMAIL_PROCESSED_LABEL=Processed by Inbotic

# Google Tasks Settings
TASKS_DEFAULT_LIST=Inbotic
TASKS_DEADLINES_LIST=Deadlines
TASKS_ACTIONS_LIST=Actions

# Processing Settings
PROCESS_DEADLINES=true
PROCESS_ACTION_ITEMS=true
PROCESS_FORMS=true

# Auto process new mail (optional background polling)
# When true, backend automatically scans recent emails and creates tasks.
INBOTIC_AUTO_PROCESS_NEW_MAIL=false
# Poll interval in seconds (minimum 30)
INBOTIC_AUTO_PROCESS_INTERVAL_SECONDS=120
# How far back to scan each polling cycle
INBOTIC_AUTO_PROCESS_DAYS_BACK=1
# Max recent emails to scan per user each cycle
INBOTIC_AUTO_PROCESS_MAX_EMAILS=20
# Task creation settings for auto mode
INBOTIC_AUTO_PROCESS_PRE_REMINDER_DAYS=1
INBOTIC_AUTO_PROCESS_MAX_DAYS_AHEAD=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=inbox_agent.log

# Security
# Generate strong random values before deployment
SECRET_KEY=replace-with-strong-random-secret
DECODER_SECRET_KEY=replace-with-strong-random-secret
